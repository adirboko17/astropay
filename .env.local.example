# Supabase — copy to .env.local and fill in values from the Supabase dashboard.
# Use the publishable key (sb_publishable_...) — never put service_role or PayPlus keys in NEXT_PUBLIC vars.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Server only — for internal pages (credentials). Never expose in the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PayPlus — server only (הוראות קבע). Do not use NEXT_PUBLIC_ prefix.
# Used by Next.js server code and optional local tools; hosted Edge Function sync also
# needs the same names in Supabase Dashboard → Edge Functions → Secrets.
PAYPLUS_API_KEY=your_payplus_api_key
PAYPLUS_SECRET_KEY=your_payplus_secret_key
PAYPLUS_TERMINAL_UID=your_terminal_uid
# Production example; use sandbox URL from PayPlus if applicable.
PAYPLUS_API_BASE_URL=https://restapi.payplus.co.il/api/v1.0
